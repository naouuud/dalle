<section class="mx-auto w-full max-w-lg px-4 py-12">
  <div class="border border-neutral-800 px-8 py-10 text-center">
    <div class="border-b border-neutral-300 pb-6 mb-6">
      <h2 class="text-xl uppercase tracking-[0.2em] font-semibold">
        Become a collector
      </h2>
    </div>

    <p class="font-['Libre_Franklin'] mb-8 text-base italic leading-relaxed text-neutral-600">
      Join the mailing list for new works, screenings, and occasional exclusive material.
    </p>

    <form class="mx-auto flex max-w-xs flex-col gap-5">
      <label class="flex flex-col gap-2 text-left">
        <span class="text-xs uppercase tracking-widest text-neutral-400">
          Email
        </span>
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder=""
          class="w-full select-text border border-neutral-300 bg-transparent px-3 py-2 text-left text-sm outline-none transition-colors placeholder:text-neutral-400 focus:border-neutral-800"
        />
      </label>
      <button
        type="submit"
        class="font-['Montserrat'] border border-neutral-800 px-6 py-2 text-xs uppercase tracking-widest text-neutral-800 transition-colors hover:bg-neutral-800 hover:text-neutral-100"
      >
        Join
      </button>
    </form>
  </div>
</section>

---
import { PortableText } from "astro-portabletext";
import ContactInfo from "./ContactInfo.astro";

const { heading, text } = Astro.props;
---
<div class="flex flex-col gap-3">
  <p class="prose leading-relaxed">{Array.isArray(text) && <PortableText value={text} />}
  {heading.toLowerCase() === "contact" && <ContactInfo />}
</div>

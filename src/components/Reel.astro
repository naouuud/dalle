---
import { type SanityImageSource, createImageUrlBuilder } from "@sanity/image-url";
import { sanityClient } from "sanity:client";
import { withBase } from "../utils/url";
import "plyr/dist/plyr.css";

type ReelItem = {
  imageUrl: string | null;
  imageWidth?: number;
  imageHeight?: number;
  media: { type: string; imageItem?: { alt?: string } };
  slug?: { current?: string };
  videoUrl: string | null;
};

type Orientation = "landscape" | "portrait";

const { reel } = Astro.props as { reel?: { reelItems?: ReelItem[] } };
const reelItems = reel?.reelItems ?? [];

const { projectId, dataset } = sanityClient.config();
const urlFor = (source: SanityImageSource) =>
  projectId && dataset
    ? createImageUrlBuilder({ projectId, dataset }).image(source)
    : null;

const getOrientation = (item: ReelItem): Orientation | null => {
  if (item.imageWidth && item.imageHeight) {
    return item.imageHeight > item.imageWidth ? "portrait" : "landscape";
  }

  if (item.media.type === "video") {
    return "landscape";
  }

  return null;
};
---

<div id="reel-gallery" class="reel-gallery">
  {
    reelItems.map((item) => {
      const { imageUrl, media, slug, videoUrl } = item;
      const orientation = getOrientation(item);
      const orientationClass =
        orientation === "portrait" ? "reel-frame--portrait" : "reel-frame--landscape";

      return (
        <div
          class:list={["reel-frame", orientationClass, "overflow-hidden"]}
          data-orientation-known={orientation ? "true" : undefined}
        >
          {media.type === "image" && imageUrl ? (
            slug?.current ? (
              <a class="reel-link" href={withBase(`work/${slug.current}`)}>
                <img
                  class="reel-media"
                  src={urlFor(imageUrl)?.width(1200).url()}
                  alt={media.imageItem?.alt ?? ""}
                  loading="lazy"
                  decoding="async"
                />
              </a>
            ) : (
              <img
                class="reel-media"
                src={urlFor(imageUrl)?.width(1200).url()}
                alt={media.imageItem?.alt ?? ""}
                loading="lazy"
                decoding="async"
              />
            )
          ) : videoUrl ? (
            <div class="reel-player">
              <video class="reel-video" autoplay muted playsinline loop>
                <source src={videoUrl} type="video/mp4" />
              </video>
            </div>
          ) : null}
        </div>
      );
    })
  }
</div>

<style>
  .reel-gallery {
    --reel-gap: 10px;
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
  }

  .reel-frame--landscape {
    aspect-ratio: 3 / 2;
  }

  .reel-frame--portrait {
    aspect-ratio: 3 / 4;
  }

  .reel-link {
    display: block;
    height: 100%;
    overflow: hidden;
  }

  .reel-player {
    display: flex;
    width: 100%;
    height: 100%;
    --plyr-color-main: hsl(274, 8%, 41%);
  }

  .reel-media {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .reel-player :global(.plyr) {
    flex: 1;
    min-width: 0;
    min-height: 0;
    width: 100%;
  }

  .reel-player :global(.plyr__video-wrapper) {
    height: 100%;
  }

  .reel-player :global(.plyr__video-wrapper video) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .reel-player :global(.plyr__controls) {
    z-index: 2;
  }

  @media (min-width: 768px) {
    .reel-gallery {
      container-type: inline-size;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--reel-gap);
      grid-auto-rows: calc((100cqw - 3 * var(--reel-gap)) / 4 * 4 / 3);
    }

    .reel-frame {
      min-width: 0;
      height: 100%;
      aspect-ratio: unset;
    }

    .reel-frame--landscape {
      grid-column: span 2;
    }

    .reel-frame--portrait {
      grid-column: span 1;
    }
  }
</style>

<script>
  import Plyr from "plyr";

  const gallery = document.getElementById("reel-gallery");

  const initPlyr = (video: HTMLVideoElement) => {
    if (video.dataset.plyrInitialized === "true") return;
    video.dataset.plyrInitialized = "true";

    const player = new Plyr(video, {
      muted: true,
      loop: { active: true },
      hideControls: false,
      controls: ["play", "progress", "current-time", "mute", "volume", "fullscreen"],
    });
    player.on("ready", () => {
      player.muted = true;
      player.play();
    });
  };

  const plyrObserver = new IntersectionObserver(
    (entries, obs) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          initPlyr(entry.target as HTMLVideoElement);
          obs.unobserve(entry.target);
        }
      });
    },
    { rootMargin: "200px" },
  );

  document.querySelectorAll<HTMLVideoElement>(".reel-video").forEach((video) => {
    plyrObserver.observe(video);
  });

  const setOrientation = (frame: HTMLElement, width: number, height: number) => {
    const orientation = height > width ? "portrait" : "landscape";

    frame.classList.remove("reel-frame--landscape", "reel-frame--portrait");
    frame.classList.add(
      orientation === "portrait" ? "reel-frame--portrait" : "reel-frame--landscape",
    );
    frame.dataset.orientationKnown = "true";
  };

  const updateMissingOrientations = () => {
    if (!gallery) return;

    gallery.querySelectorAll<HTMLElement>(".reel-frame").forEach((frame) => {
      if (frame.dataset.orientationKnown === "true") return;

      const img = frame.querySelector("img");
      if (!img?.naturalWidth || !img.naturalHeight) return;

      setOrientation(frame, img.naturalWidth, img.naturalHeight);
    });
  };

  gallery?.querySelectorAll("img").forEach((img) => {
    if (img.complete) {
      updateMissingOrientations();
      return;
    }

    img.addEventListener("load", updateMissingOrientations, { once: true });
    img.addEventListener("error", updateMissingOrientations, { once: true });
  });
</script>

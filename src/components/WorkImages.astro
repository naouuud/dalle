---
import { type SanityImageSource, createImageUrlBuilder } from "@sanity/image-url";
import { sanityClient } from "sanity:client";
import "plyr/dist/plyr.css";

type MediaItem = {
  type: "image" | "video";
  image?: SanityImageSource;
  alt?: string;
  videoUrl?: string;
};

const { allMedia = [] } = Astro.props as { allMedia?: MediaItem[] };
const { projectId, dataset } = sanityClient.config();
const urlFor = (source: SanityImageSource) =>
  projectId && dataset
    ? createImageUrlBuilder({ projectId, dataset }).image(source)
    : null;

const imageItems = allMedia.filter((m) => m.type === "image");
---

<div class="flex flex-col gap-2">
  {
    allMedia.map((item) => {
      if (item.type === "video") {
        return (
          <div class="work-player">
            <video class="work-video w-full" playsinline controls>
              <source src={item.videoUrl} type="video/mp4" />
            </video>
          </div>
        );
      }

      const lightboxIndex = imageItems.indexOf(item);
      return (
        <div>
          <img
            class="cursor-pointer"
            src={urlFor(item.image!)?.width(800).url()}
            alt={item.alt}
            data-lightbox-trigger={lightboxIndex}
          />
        </div>
      );
    })
  }
</div>

<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden bg-black/90 cursor-pointer"
  aria-hidden="true"
  role="dialog"
>
  {
    imageItems.map((item, index) => (
      <div
        class="absolute inset-0 hidden w-full items-center justify-center"
        data-lightbox-slide={index}
      >
        <img
          class="block h-auto w-full max-h-[90vh] object-contain pointer-events-none"
          src={urlFor(item.image!)?.width(2400).url()}
          alt={item.alt}
        />
      </div>
    ))
  }
</div>

<style>
  .work-player {
    --plyr-color-main: hsl(274, 8%, 41%);
  }
</style>

<script>
  import Plyr from "plyr";

  document.addEventListener("DOMContentLoaded", () => {
    // --- Plyr (deferred until each video enters the viewport) ---
    const initPlyr = (video: HTMLVideoElement) => {
      new Plyr(video, {
        autoplay: false,
        muted: false,
        controls: ["play", "progress", "current-time", "mute", "volume", "fullscreen"],
      });
    };

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            initPlyr(entry.target as HTMLVideoElement);
            obs.unobserve(entry.target);
          }
        });
      },
      { rootMargin: "200px" },
    );

    document.querySelectorAll<HTMLVideoElement>(".work-video").forEach((video) => {
      observer.observe(video);
    });

    // --- Lightbox ---
    const lightbox = document.getElementById("lightbox");
    const slides = lightbox?.querySelectorAll<HTMLElement>("[data-lightbox-slide]");
    const triggers = document.querySelectorAll<HTMLElement>("[data-lightbox-trigger]");

    if (!lightbox || !slides?.length) return;

    const showSlide = (index: number) => {
      slides.forEach((slide) => {
        const isActive = Number(slide.getAttribute("data-lightbox-slide")) === index;
        slide.classList.toggle("hidden", !isActive);
        slide.classList.toggle("flex", isActive);
      });
    };

    const openLightbox = (index: number) => {
      showSlide(index);
      lightbox.classList.remove("hidden");
      lightbox.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    };

    const closeLightbox = () => {
      lightbox.classList.add("hidden");
      lightbox.setAttribute("aria-hidden", "true");
      slides.forEach((slide) => {
        slide.classList.add("hidden");
        slide.classList.remove("flex");
      });
      document.body.style.overflow = "";
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const index = Number(trigger.getAttribute("data-lightbox-trigger"));
        openLightbox(index);
      });
    });

    lightbox.addEventListener("click", closeLightbox);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && lightbox.getAttribute("aria-hidden") === "false") {
        closeLightbox();
      }
    });
  });
</script>

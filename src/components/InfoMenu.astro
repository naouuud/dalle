---
import MenuText from "./MenuText.astro";
import { sanityClient } from "sanity:client";
import type { SanityDocument } from "sanity";

const MENU_QUERY = `*[_type == 'menu'][0]`;
const menu = await sanityClient.fetch<SanityDocument & { menuItems: Array<{ heading: string; text: any }> }>(MENU_QUERY);
const menuItems = menu?.menuItems ?? [];
---

<div class="info-menu flex w-full min-w-0 flex-col gap-8 self-start px-4 lg:gap-6 lg:self-start lg:px-0">
  <div class="flex items-start gap-6 sm:gap-10 lg:items-start lg:gap-10 xl:gap-12">
    <nav class="flex w-max shrink-0 flex-col gap-2 lg:gap-1.5" aria-label="About sections">
      {
        menuItems.map((item, i) => (
          <button
            type="button"
            data-index={i}
            class="info-menu-tab m-0 whitespace-nowrap border-0 bg-transparent text-left uppercase text-sm leading-normal tracking-wide text-neutral-400 transition-colors hover:text-black hover:cursor-pointer lg:-ml-px lg:border-l-2 lg:border-transparent lg:pl-3 lg:tracking-[0.12em] lg:aria-[current=true]:border-neutral-900 lg:aria-[current=true]:text-neutral-900"
            aria-current={i === 0 ? "true" : "false"}
          >
            {item.heading}
          </button>
        ))
      }
    </nav>

    <div class="info-menu-panels min-w-0 flex-1 lg:-translate-y-1 max-lg:grid max-lg:[&>.info-menu-panel]:col-start-1 max-lg:[&>.info-menu-panel]:row-start-1">
      {
        menuItems.map((item, i) => (
          <div
            class:list={["info-menu-panel", i !== 0 && "hidden"]}
            data-panel={i}
            aria-hidden={i !== 0 ? "true" : "false"}
          >
            <MenuText heading={item.heading} text={item.text} />
          </div>
        ))
      }
    </div>
  </div>

  <!-- <SocialMedia /> -->
</div>

<script>
  const menuTabs = document.querySelectorAll<HTMLButtonElement>(".info-menu-tab");
  const menuPanels = document.querySelectorAll<HTMLElement>(".info-menu-panel");
  const desktopQuery = window.matchMedia("(min-width: 1024px)");

  let activeIndex = 0;

  const setActivePanel = (index: number) => {
    activeIndex = index;

    menuTabs.forEach((tab, i) => {
      tab.setAttribute("aria-current", i === index ? "true" : "false");
      tab.classList.toggle("text-black", i === index);
      tab.classList.toggle("font-medium", i === index);
      tab.classList.toggle("text-neutral-400", i !== index);
    });

    menuPanels.forEach((panel, i) => {
      const active = i === index;

      if (desktopQuery.matches) {
        panel.classList.toggle("hidden", !active);
        panel.classList.remove("invisible", "pointer-events-none");
      } else {
        panel.classList.remove("hidden");
        panel.classList.toggle("invisible", !active);
        panel.classList.toggle("pointer-events-none", !active);
      }

      panel.setAttribute("aria-hidden", active ? "false" : "true");
    });
  };

  menuTabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const index = Number(tab.dataset.index);
      if (!Number.isNaN(index)) setActivePanel(index);
    });
  });

  desktopQuery.addEventListener("change", () => setActivePanel(activeIndex));

  if (menuTabs.length) setActivePanel(0);
</script>

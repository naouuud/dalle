---
import '../styles/global.css';
import { withBase } from '../utils/url';
const { page } = Astro.props
import Navbar from '../components/Navbar';
import Menu from '../components/Menu.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={withBase("favicon.ico")} />
		<title>Rumi Dalle &ndash; {page ? page : "Artist"}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Libre+Franklin:ital,wght@0,100..900;1,100..900&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Raleway:ital,wght@0,100..900;1,100..900&display=optional"
		/>
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Libre+Franklin:ital,wght@0,100..900;1,100..900&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Raleway:ital,wght@0,100..900;1,100..900&display=optional"
		/>
	</head>
	<body>
		<Menu />
		<div id="page" class="bg-neutral-100 transition-transform duration-500 ease-out">
			<Navbar client:load />
			<slot />
			<Footer />
		</div>
	</body>
</html>

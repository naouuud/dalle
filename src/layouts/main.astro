---
import '../styles/global.css';
import { withBase } from '../utils/url';
const { page } = Astro.props
import Navbar from '../components/Navbar';
import Footer from '../components/Footer.astro';
import FontFaces from '../components/FontFaces.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={withBase("favicon.ico")} />
		<title>Rumi Dalle &ndash; {page ? page : "Artist"}</title>
		<FontFaces />
	</head>
	<body>
		<div id="page" class="bg-neutral-100 transition-transform duration-500 ease-out">
			<Navbar client:load />
			<slot />
			<Footer />
		</div>
	</body>
</html>

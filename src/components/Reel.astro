---
import { type SanityImageSource, createImageUrlBuilder } from "@sanity/image-url";
import { sanityClient } from "sanity:client"

const { reel } = Astro.props;

const { projectId, dataset } = sanityClient.config();
const urlFor = (source: SanityImageSource) => 
  projectId && dataset
    ? createImageUrlBuilder({ projectId, dataset }).image(source)
    : null;
---
<div class="flex flex-col gap-4">
    {
      reel.reelItems.map(
        ({
          imageItem,
          slug,
        }: {
          imageItem: { image: SanityImageSource; alt: string };
          title: string;
          slug: { current: string };
        }) => (
          <div>
            {slug.current ? (
              <a href={"work/" + slug.current}>
                <img
                  src={urlFor(imageItem.image)?.width(800).url()}
                  alt={imageItem.alt}
                />
              </a>
            ) : (
              <img
                src={urlFor(imageItem.image)?.width(800).url()}
                alt={imageItem.alt}
              />
            )}
          </div>
        ),
      )
    }
</div>
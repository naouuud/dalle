---
import SocialMedia from "./SocialMedia.astro";
import MenuText from "./MenuText.astro";
import { sanityClient } from "sanity:client";
import type { SanityDocument } from "sanity";

const MENU_QUERY = `*[_type == 'menu'][0]`;
const menu = await sanityClient.fetch<SanityDocument & { menuItems: Array<{ heading: string; text: any }> }>(MENU_QUERY);
const menuItems = menu?.menuItems ?? [];
---

<div
  id="menu-backdrop"
  class="fixed inset-0 z-40 bg-black/20 opacity-0 pointer-events-none transition-opacity duration-500"
></div>

<aside
  id="menu"
  class="fixed right-0 top-0 z-50 flex h-dvh w-full max-w-md flex-col bg-neutral-100 border-l border-neutral-200 translate-x-full transition-transform duration-500 ease-out"
  aria-hidden="true"
>
  <div class="flex items-center justify-between px-6 pt-6 pb-4 border-b border-neutral-200">
    <span class="tracking-wide text-sm text-neutral-500">About</span>
    <button
      id="menu-close"
      type="button"
      class="text-sm text-neutral-500 hover:text-black transition-colors hover:cursor-pointer"
    >
      Close
    </button>
  </div>

  <nav class="flex gap-6 px-6 py-4 border-b border-neutral-200 overflow-auto" aria-label="Info sections">
    {
      menuItems.map((item, i) => (
        <button
          type="button"
          data-index={i}
          class="menu-tab uppercase text-sm tracking-wide text-neutral-400 hover:text-black transition-colors hover:cursor-pointer"
          aria-current={i === 0 ? "true" : "false"}
        >
          {item.heading}
        </button>
      ))
    }
  </nav>

  <div class="flex-1 overflow-y-auto px-6 py-6">
    {
      menuItems.map((item, i) => (
        <div class:list={["menu-panel", i !== 0 && "hidden"]} data-panel={i}>
          <MenuText heading={ item.heading } text={item.text} />
        </div>
      ))
    }
  </div>

  <div class="px-6 py-6 border-t border-neutral-200">
    <SocialMedia />
  </div>
</aside>

<script>
  const menu = document.getElementById("menu");
  const backdrop = document.getElementById("menu-backdrop");
  const closeButton = document.getElementById("menu-close");
  const menuTabs = document.querySelectorAll<HTMLButtonElement>(".menu-tab");
  const menuPanels = document.querySelectorAll<HTMLElement>(".menu-panel");
  const menuOpenButton = document.getElementById("menu-open");

  let open = false;
  let activeIndex = 0;

  const setActivePanel = (index: number) => {
    activeIndex = index;
    menuTabs.forEach((tab, i) => {
      tab.setAttribute("aria-current", i === index ? "true" : "false");
      tab.classList.toggle("text-black", i === index);
      tab.classList.toggle("font-medium", i === index);
      tab.classList.toggle("text-neutral-400", i !== index);
    });
    menuPanels.forEach((panel, i) => {
      panel.classList.toggle("hidden", i !== index);
    });
  };

  const setMenu = (state: boolean) => {
    open = state;

    setActivePanel(0);

    menu?.classList.toggle("translate-x-0", open);
    menu?.classList.toggle("translate-x-full", !open);
    menu?.setAttribute("aria-hidden", open ? "false" : "true");

    backdrop?.classList.toggle("opacity-100", open);
    backdrop?.classList.toggle("pointer-events-auto", open);
    backdrop?.classList.toggle("opacity-0", !open);
    backdrop?.classList.toggle("pointer-events-none", !open);

    menuOpenButton?.setAttribute("aria-expanded", open ? "true" : "false");

    if (open) {
      setActivePanel(activeIndex);
      document.body.style.overflow = "hidden";
    } else {
      document.body.style.overflow = "";
    }
  };

  window.addEventListener("toggle-menu", () => {
    setMenu(!open);
  });

  closeButton?.addEventListener("click", () => setMenu(false));
  backdrop?.addEventListener("click", () => setMenu(false));

  menuTabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const index = Number(tab.dataset.index);
      if (!Number.isNaN(index)) setActivePanel(index);
    });
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && open) setMenu(false);
  });

  setActivePanel(0);
</script>

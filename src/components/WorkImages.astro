---
import { type SanityImageSource, createImageUrlBuilder } from "@sanity/image-url";
import { sanityClient } from "sanity:client";
import "plyr/dist/plyr.css";

type MediaItem = {
  type: "image" | "video";
  image?: SanityImageSource;
  alt?: string;
  videoUrl?: string;
};

const {
  allMedia = [],
  layout = "stack",
  galleryId = "default",
  lightboxId = "lightbox",
} = Astro.props as {
  allMedia?: MediaItem[];
  layout?: "stack" | "scroll";
  galleryId?: string;
  lightboxId?: string;
};
const { projectId, dataset } = sanityClient.config();
const urlFor = (source: SanityImageSource) =>
  projectId && dataset
    ? createImageUrlBuilder({ projectId, dataset }).image(source)
    : null;

const imageItems = allMedia.filter((m) => m.type === "image");
---

<div
  data-work-gallery={galleryId}
  class:list={[
    layout === "scroll"
      ? "work-gallery-scroll flex h-[calc(100vh-6.5rem)] snap-x snap-mandatory gap-4 overflow-x-auto overflow-y-hidden px-1 pb-2"
      : "flex flex-col gap-2",
  ]}
>
  {
    allMedia.map((item) => {
      if (item.type === "video") {
        return (
          <div class:list={[layout === "scroll" && "work-gallery-item shrink-0 snap-center"]}>
            <div class:list={["work-player", layout === "scroll" && "work-player--scroll"]}>
              <video class:list={["work-video", layout === "scroll" ? "h-full w-auto" : "w-full"]} playsinline controls>
                <source src={item.videoUrl} type="video/mp4" />
              </video>
            </div>
          </div>
        );
      }

      const lightboxIndex = imageItems.indexOf(item);
      const imageWidth = layout === "scroll" ? 1600 : 800;
      return (
        <div class:list={[layout === "scroll" && "work-gallery-item shrink-0 snap-center"]}>
          <img
            class:list={["cursor-pointer", layout === "scroll" && "work-gallery-image"]}
            src={urlFor(item.image!)?.width(imageWidth).url()}
            alt={item.alt}
            data-lightbox-trigger={lightboxIndex}
            data-lightbox-gallery={galleryId}
          />
        </div>
      );
    })
  }
</div>

<div
  id={lightboxId}
  data-lightbox-for={galleryId}
  class="fixed inset-0 z-50 hidden bg-black/90 cursor-pointer"
  aria-hidden="true"
  role="dialog"
>
  {
    imageItems.map((item, index) => (
      <div
        class="absolute inset-0 hidden w-full items-center justify-center"
        data-lightbox-slide={index}
      >
        <img
          class="block h-auto w-full max-h-[90vh] object-contain pointer-events-none"
          src={urlFor(item.image!)?.width(2400).url()}
          alt={item.alt}
        />
      </div>
    ))
  }
</div>

<style>
  .work-player {
    --plyr-color-main: hsl(274, 8%, 41%);
  }

  .work-player--scroll {
    height: min(75vh, 720px);
    aspect-ratio: 16 / 9;
  }

  .work-gallery-image {
    height: min(75vh, 720px);
    width: auto;
    max-width: none;
    object-fit: contain;
  }

  .work-gallery-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .work-gallery-scroll::-webkit-scrollbar {
    display: none;
  }
</style>

<script define:vars={{ galleryId, lightboxId }}>
  document.addEventListener("DOMContentLoaded", () => {
    const gallery = document.querySelector(`[data-work-gallery="${galleryId}"]`);
    if (!gallery || gallery.dataset.lightboxInit === "true") return;

    const lightbox = document.getElementById(lightboxId);
    const slides = lightbox?.querySelectorAll("[data-lightbox-slide]");
    const triggers = gallery.querySelectorAll("[data-lightbox-trigger]");

    if (!lightbox || !slides?.length || !triggers.length) return;

    gallery.dataset.lightboxInit = "true";

    const showSlide = (index) => {
      slides.forEach((slide) => {
        const isActive = Number(slide.getAttribute("data-lightbox-slide")) === index;
        slide.classList.toggle("hidden", !isActive);
        slide.classList.toggle("flex", isActive);
      });
    };

    const openLightbox = (index) => {
      showSlide(index);
      lightbox.classList.remove("hidden");
      lightbox.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    };

    const closeLightbox = () => {
      lightbox.classList.add("hidden");
      lightbox.setAttribute("aria-hidden", "true");
      slides.forEach((slide) => {
        slide.classList.add("hidden");
        slide.classList.remove("flex");
      });
      document.body.style.overflow = "";
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", (event) => {
        event.stopPropagation();
        const index = Number(trigger.getAttribute("data-lightbox-trigger"));
        if (!Number.isNaN(index)) openLightbox(index);
      });
    });

    lightbox.addEventListener("click", closeLightbox);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && lightbox.getAttribute("aria-hidden") === "false") {
        closeLightbox();
      }
    });
  });
</script>

<script define:vars={{ galleryId }}>
  document.addEventListener("DOMContentLoaded", () => {
    const gallery = document.querySelector(`[data-work-gallery="${galleryId}"]`);
    if (!gallery || gallery.dataset.plyrInit === "true") return;

    const videos = gallery.querySelectorAll(".work-video");
    if (!videos.length) return;

    gallery.dataset.plyrInit = "true";

    import("plyr")
      .then(({ default: Plyr }) => {
        const initPlyr = (video) => {
          new Plyr(video, {
            autoplay: false,
            muted: false,
            controls: ["play", "progress", "current-time", "mute", "volume", "fullscreen"],
          });
        };

        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                initPlyr(entry.target);
                obs.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "200px" },
        );

        videos.forEach((video) => observer.observe(video));
      })
      .catch(() => {});
  });
</script>

---
import WorkImages from "./WorkImages.astro";
import WorkNavigation from "./WorkNavigation.astro";

const { title, year, medium, body, allMedia, prev, next } = Astro.props;
---

<main class="mx-auto min-h-screen max-w-none px-6 pb-10 pt-24">
  <div class="mx-auto grid max-w-[1600px] grid-cols-[minmax(240px,320px)_minmax(0,1fr)] items-start gap-10 xl:grid-cols-[minmax(280px,360px)_minmax(0,1fr)] xl:gap-14">
    <aside class="sticky top-24 flex flex-col gap-8 self-start">
      <header class="space-y-3 border-b border-neutral-300 pb-6">
        <h1 class="text-sm lg:text-[0.9375rem] uppercase tracking-wide">{title}</h1>
        <p class="text-sm lg:text-[0.9375rem] italic text-neutral-500">{year}</p>
        {medium && <p class="text-sm lg:text-[0.9375rem] leading-relaxed text-neutral-600">{medium}</p>}
      </header>

      {body && (
        <div class="max-w-sm">
          <p class="text-sm lg:text-[0.9375rem] leading-relaxed text-neutral-700">{body}</p>
        </div>
      )}

      <WorkNavigation
        prev={prev}
        next={next}
        class="py-0 text-left mb-0 [&_a]:items-start"
      />
    </aside>

    <section class="min-w-0" aria-label={`Gallery for ${title}`}>
      <WorkImages
        allMedia={allMedia}
        layout="scroll"
        galleryId="desktop"
        lightboxId="work-lightbox-desktop"
      />
    </section>
  </div>
</main>

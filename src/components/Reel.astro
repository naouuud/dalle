---
import { type SanityImageSource, createImageUrlBuilder } from "@sanity/image-url";
import { sanityClient } from "sanity:client"
import "plyr/dist/plyr.css";

const { reel } = Astro.props;
const { reelItems } = reel;

const { projectId, dataset } = sanityClient.config();
const urlFor = (source: SanityImageSource) => 
  projectId && dataset
    ? createImageUrlBuilder({ projectId, dataset }).image(source)
    : null;
---
<div class="flex flex-col gap-0">
    {
      reelItems.map(
        ({
          imageUrl,
          media,
          slug,
          videoUrl,
        }: {
          imageUrl: string | null;
          media: any;
          slug: { current: string };
          videoUrl: string | null;
        }) => 
          <div>
          { media.type === "image" ? 
            slug.current ? (
              <a href={"work/" + slug.current}>
                <img
                  src={urlFor(imageUrl!)?.width(800).url()}
                  alt={media.imageItem.alt}
                />
              </a>
            ) : (
              <img
                src={urlFor(imageUrl!)?.width(800).url()}
                alt={media.imageItem.alt}
              />
            ) : 
              <div class="reel-player">
              <video
                class="reel-video w-full"
                autoplay
                muted
                playsinline
                loop
                controls
              >
                <source src={videoUrl} type="video/mp4" />
              </video>
              </div>
          }
          </div>
        )}
</div>

<style>
  .reel-player {
    --plyr-color-main: hsl(274, 8%, 41%);
  }
</style>

<script>
  import Plyr from "plyr";

  document.querySelectorAll<HTMLVideoElement>(".reel-video").forEach((video) => {
    new Plyr(video, {
      controls: ["play", "progress", "current-time", "mute", "volume", "fullscreen"],
    });
  });
</script>
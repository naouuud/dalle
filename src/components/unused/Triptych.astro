---
import { type SanityImageSource, createImageUrlBuilder } from "@sanity/image-url";
import { sanityClient } from "sanity:client";

interface Triptych {
    left: any,
    center: any,
    right: any
}

const POST_QUERY = `*[_type == "triptych"][0]`;
const triptych = await sanityClient.fetch<Triptych>(POST_QUERY);

const { projectId, dataset } = sanityClient.config();
const urlFor = (source: SanityImageSource) =>
  projectId && dataset
    ? createImageUrlBuilder({ projectId, dataset }).image(source)
    : null;
const imageURLs = [
  triptych.left?.image ? urlFor(triptych.left.image)?.width(800).height(500).blur(50).url() : null,
  triptych.center?.image ? urlFor(triptych.center.image)?.width(800).height(500).blur(50).url() : null,
  triptych.right?.image ? urlFor(triptych.right.image)?.width(800).height(500).blur(50).url() : null,
];
const imageAlts = [
  triptych.left?.alt ? triptych.left.alt : "",
  triptych.left?.alt ? triptych.left.alt : "",
  triptych.left?.alt ? triptych.left.alt : "",
]
const array = [{
    url: imageURLs[0], alt: imageAlts[0]
}, {
    url: imageURLs[1], alt: imageAlts[1]
}, {
    url: imageURLs[2], alt: imageAlts[2]
}]

const menuList = ["Story", "Portfolio", "CV"]

---
<div class="lg:flex">
    {
      array.map((item, index) =>  (
        <div class="relative">
          <img
            src={item.url}
            alt={item.alt}
            class="rounded-sm"
          />
        <div class="text-white/50 text-4xl absolute inset-y-1/2">{menuList[index]}</div>
        </div>
      ))
    }
</div>

---
import { type SanityImageSource, createImageUrlBuilder } from "@sanity/image-url";
import { sanityClient } from "sanity:client"

const { images } = Astro.props;
const { projectId, dataset } = sanityClient.config();
const urlFor = (source: SanityImageSource) => 
  projectId && dataset
    ? createImageUrlBuilder({ projectId, dataset }).image(source)
    : null;
---
<div class="flex flex-col gap-4">
    {
      images.map(
        (image: any, index: number) => (
          <div>
              <img
                class="cursor-pointer"
                src={urlFor(image.image)?.width(800).url()}
                alt={image.alt}
                data-lightbox-trigger={index}
              /> 
          </div>
        ),
      )
    }
</div>

<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 cursor-pointer"
  aria-hidden="true"
  role="dialog"
>
  {
    images.map(
      (image: any, index: number) => (
        <div class="hidden" data-lightbox-slide={index}>
          <img
            class="max-h-[90vh] max-w-[90vw] object-contain pointer-events-none"
            src={urlFor(image.image)?.width(1600).url()}
            alt={image.alt}
          />
        </div>
      ),
    )
  }
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const lightbox = document.getElementById("lightbox");
    const slides = lightbox?.querySelectorAll<HTMLElement>("[data-lightbox-slide]");
    const triggers = document.querySelectorAll<HTMLElement>("[data-lightbox-trigger]");

    if (!lightbox || !slides?.length) return;

    const showSlide = (index: number) => {
      slides.forEach((slide) => {
        slide.classList.toggle(
          "hidden",
          Number(slide.getAttribute("data-lightbox-slide")) !== index,
        );
      });
    };

    const open = (index: number) => {
      showSlide(index);
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      lightbox.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    };

    const close = () => {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      lightbox.setAttribute("aria-hidden", "true");
      slides.forEach((slide) => slide.classList.add("hidden"));
      document.body.style.overflow = "";
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const index = Number(trigger.getAttribute("data-lightbox-trigger"));
        open(index);
      });
    });

    lightbox.addEventListener("click", close);

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && lightbox.getAttribute("aria-hidden") === "false") {
        close();
      }
    });
  });
</script>

---
const { year, medium, body} = Astro.props;
---
<div
  id="work-info"
  class="bg-neutral-100 px-0.5 top-10 w-full overflow-hidden max-h-0 transition-all duration-500 ease-in-out"
> 
  <ul class="flex flex-col gap-2 font-light">
    <li class="text-xs italic">{year}</li>
    <hr>
    <li class="text-xs leading-relaxed">{body}</li>
  </ul>
</div>
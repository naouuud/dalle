---
import SocialMedia from "./SocialMedia.astro"

const menuList = ["Artist", "Collaborations", "Contact"]
---
<div
  id="backdrop"
  class="
    fixed inset-0 z-40
    bg-black/30
    opacity-0 pointer-events-none
    transition-opacity duration-500
  "
></div>

<aside
  id="menu"
  class="
    fixed right-0 top-0 z-50
    flex h-dvh w-72 flex-col
    bg-white px-8 py-12
    shadow-2xl
    translate-x-full
    transition-transform duration-500 ease-out
  "
>
  <!-- Close button -->
  <div class="flex justify-end">
    <button
      id="menu-button"
      type="button"
      aria-label="menu"
      aria-expanded="false"
      class="text-2xl"
    >
      <!-- ←  -->
      <span class="text-lg uppercase">{"<<<"}</span>
    </button>
  </div>

  <!-- Menu items -->
  <nav class="mt-12 flex flex-col gap-8">
    {menuList.map((item) => (
      <a
        href={item.toLowerCase()}
        class="
          text-xl tracking-widest
          transition-all duration-300
          hover:translate-x-2 hover:opacity-60
          uppercase
        "
      >
        {item}
      </a>
    ))}
    <SocialMedia />
  </nav>
</aside>


---
import { withBase } from "../utils/url";

const { next } = Astro.props;
---

<nav class="py-8 text-center text-xs mb-8">
  <a href={withBase(`work/${next.slug}`)} class="group inline-flex flex-col items-center gap-2">
    <span class="font-medium group-hover:text-neutral-600">Follow the thread &rarr;</span>
    <span class="text-neutral-500 group-hover:text-black">{next.title}</span>
  </a>
</nav>

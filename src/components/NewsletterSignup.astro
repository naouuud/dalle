---
const formId = import.meta.env.PUBLIC_FORMSPREE_FORM_ID;
---

<section class="mx-auto mb-4 w-full max-w-lg shrink-0 px-4 py-8 lg:mx-0 lg:mb-0 lg:w-[18rem] lg:max-w-none lg:px-0 lg:py-0 xl:w-[19rem]">
  <div class="border border-neutral-200 bg-white px-6 py-7 text-center shadow-sm xl:px-7 xl:py-8">
    <div class="mb-5 border-b border-neutral-200 pb-4">
      <h2 class="font-['Libre Franklin'] text-sm font-semibold uppercase tracking-[0.18em] text-neutral-600">
        Become a collector
      </h2>
    </div>

    <p class="font-['Montserrat'] mb-6 text-sm lg:text-[0.8125rem] leading-relaxed text-neutral-600">
      Join the mailing list for new works, screenings, and occasional exclusive material.
    </p>

    {
      formId ? (
        <form
          id="newsletter-form"
          class="newsletter-form mx-auto flex max-w-xs flex-col gap-4 lg:max-w-none"
          novalidate
        >
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

          <label class="flex flex-col gap-2 text-left">
            <span class="text-sm lg:text-[0.8125rem] uppercase tracking-widest text-neutral-400">
              Email
            </span>
            <input
              id="newsletter-email"
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder=""
              class="w-full border border-neutral-300 bg-neutral-50 px-3 py-1.5 text-left text-sm outline-none transition-colors placeholder:text-neutral-400 focus:border-neutral-800 focus:bg-white"
            />
          </label>

          <button
            id="newsletter-submit"
            type="submit"
            class="font-['Montserrat'] border border-neutral-800 px-5 py-1.5 text-sm lg:text-[0.8125rem] uppercase tracking-[0.14em] text-neutral-800 transition-colors hover:bg-neutral-800 hover:text-neutral-100 disabled:cursor-not-allowed disabled:opacity-50"
          >
            Join
          </button>

          <p id="newsletter-status" class="hidden text-sm" role="status" aria-live="polite"></p>
        </form>
      ) : (
        <p class="font-['Montserrat'] text-sm lg:text-[0.8125rem] text-neutral-500">
          Mailing list signup is being configured.
        </p>
      )
    }
  </div>
</section>

{
  formId && (
    <script define:vars={{ formId }}>
      const form = document.getElementById("newsletter-form");
      const emailInput = document.getElementById("newsletter-email");
      const submitButton = document.getElementById("newsletter-submit");
      const status = document.getElementById("newsletter-status");

      if (!form || !emailInput || !submitButton || !status) {
        throw new Error("Newsletter form elements missing");
      }

      const showStatus = (message, type) => {
        status.textContent = message;
        status.classList.remove("hidden", "text-neutral-600", "text-red-700");
        status.classList.add(type === "error" ? "text-red-700" : "text-neutral-600");
      };

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        const email = emailInput.value.trim();
        if (!email) return;

        submitButton.disabled = true;
        status.classList.add("hidden");

        try {
          const response = await fetch(`https://formspree.io/f/${formId}`, {
            method: "POST",
            headers: {
              Accept: "application/json",
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              email,
              _subject: "New mailing list signup — Rumi Dalle",
              _replyto: email,
            }),
          });

          if (!response.ok) {
            const data = await response.json().catch(() => null);
            const message =
              data?.errors?.map((error) => error.message).join(" ") ||
              "Something went wrong. Please try again.";
            showStatus(message, "error");
            return;
          }

          form.reset();
          showStatus("Thank you — you're on the list.", "success");
        } catch {
          showStatus("Network error. Please check your connection and try again.", "error");
        } finally {
          submitButton.disabled = false;
        }
      });
    </script>
  )
}

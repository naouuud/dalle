---
import MainLayout from "../layouts/main.astro"
import Navbar from "../components/Navbar.astro"
import ContainerLayout from "../layouts/container.astro";
import Reel from "../components/Reel.astro";
import Grid from "../components/Grid.astro";
import Menu from "../components/Menu.astro";
import Biography from "../components/Biography.astro";
import Footer from "../components/Footer.astro"

export const GRID = true;
---
{
  GRID ? (
    <MainLayout page="Artist">
	  <Menu />
      <main id="page" class="transition-transform duration-500 ease-out mx-auto min-h-screen max-w-3xl lg:flex">
        <Navbar />
		<Grid />
		<ContainerLayout>
			<Biography />
			<Footer />
		</ContainerLayout>
      </main>
    </MainLayout>
  ) : (
    <MainLayout page="Artist">
	  <Menu />
      <main id="page" class="transition-transform duration-500 ease-out mx-auto min-h-screen max-w-3xl lg:flex">
        <Navbar />
	    <ContainerLayout>
			<Reel />
			<Biography />
			<Footer />
		</ContainerLayout>
      </main>
    </MainLayout>
  )
}


---
import { withBase } from "../utils/url";

const ralewayNormal = withBase("fonts/raleway/Raleway-VariableFont_wght.ttf");
const ralewayItalic = withBase("fonts/raleway/Raleway-Italic-VariableFont_wght.ttf");
const montserratNormal = withBase("fonts/monserrat/Montserrat-VariableFont_wght.ttf");
const montserratItalic = withBase("fonts/monserrat/Montserrat-Italic-VariableFont_wght.ttf");
const libreFranklinNormal = withBase("fonts/libre-franklin/LibreFranklin-VariableFont_wght.ttf");

const fontFaceCss = `
@font-face {
  font-family: "Raleway";
  font-style: normal;
  font-weight: 100 900;
  font-display: swap;
  src: url("${ralewayNormal}") format("truetype");
}

@font-face {
  font-family: "Raleway";
  font-style: italic;
  font-weight: 100 900;
  font-display: swap;
  src: url("${ralewayItalic}") format("truetype");
}

@font-face {
  font-family: "Montserrat";
  font-style: normal;
  font-weight: 100 900;
  font-display: swap;
  src: url("${montserratNormal}") format("truetype");
}

@font-face {
  font-family: "Montserrat";
  font-style: italic;
  font-weight: 100 900;
  font-display: swap;
  src: url("${montserratItalic}") format("truetype");
}

@font-face {
  font-family: "Libre Franklin";
  font-style: normal;
  font-weight: 100 900;
  font-display: swap;
  src: url("${libreFranklinNormal}") format("truetype");
}
`;
---

<link rel="preload" href={ralewayNormal} as="font" type="font/ttf" crossorigin />
<Fragment set:html={`<style>${fontFaceCss}</style>`} />

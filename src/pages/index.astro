---
import MainLayout from "../layouts/main.astro"
import Navbar from "../components/Navbar.astro"
import ContainerLayout from "../layouts/container.astro";
import Reel from "../components/Reel.astro";
import Grid from "../components/Grid.astro";

export const GRID = true;
---

{
  GRID ? (
    <MainLayout page="Artist">
      <main class="mx-auto min-h-screen max-w-3xl lg:flex">
        <Navbar />
        <Grid />
      </main>
    </MainLayout>
  ) : (
    <MainLayout page="Artist">
      <main class="mx-auto min-h-screen max-w-3xl lg:flex">
        <Navbar />
		<ContainerLayout>
          <Reel />
        </ContainerLayout>
      </main>
    </MainLayout>
  )
}

